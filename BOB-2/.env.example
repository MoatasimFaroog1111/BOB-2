# GuardianAI Accountant & Auditor Enterprise — Environment
# Copy to .env. Never commit the populated .env file.

# Application
APP_NAME="GuardianAI Accountant & Auditor Enterprise"
APP_ENV=local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_BIND_IP=127.0.0.1
FRONTEND_PORT=3000
FRONTEND_BIND_IP=127.0.0.1
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=
TRUSTED_HOSTS=
# REQUIRED in production: exact reverse-proxy IPs/CIDRs only.
TRUSTED_PROXY_IPS=

# Database
# Local development may use sqlite:///./guardianai.db.
# Production must use PostgreSQL with a URL-encoded strong password.
POSTGRES_USER=guardian
POSTGRES_PASSWORD=
POSTGRES_DB=guardianai
DATABASE_URL=

# Shared rate limiting and session protection
REDIS_PASSWORD=
REDIS_URL=

# Security
# REQUIRED in production. Generate with: openssl rand -hex 64
SECRET_KEY=
REQUIRE_HTTPS=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=3

# Telegram runtime — disabled by default.
# Do not set PRODUCTION_READY=true until secret-store and remaining production
# hardening stages are complete.
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_PRODUCTION_READY=false
# Group and supergroup chats require this global opt-in plus an allowlist-row opt-in.
TELEGRAM_ALLOW_GROUP_CHATS=false
# One-time accounting approvals expire after this many seconds (production: 60–3600).
TELEGRAM_APPROVAL_TTL_SECONDS=600
# Fixed-worker ingestion queue. No upload creates its own thread.
TELEGRAM_INGESTION_WORKERS=2
TELEGRAM_INGESTION_QUEUE_SIZE=20
TELEGRAM_MAX_PENDING_PER_ACTOR=1
TELEGRAM_MAX_PENDING_PER_ORGANIZATION=5
TELEGRAM_UPLOAD_RATE_LIMIT=5
TELEGRAM_UPLOAD_RATE_WINDOW_SECONDS=60
TELEGRAM_INGESTION_JOB_TTL_SECONDS=300
TELEGRAM_DOWNLOAD_TIMEOUT_SECONDS=30
TELEGRAM_DOWNLOAD_CHUNK_SIZE_BYTES=65536
TELEGRAM_MESSAGE_MAX_AGE_SECONDS=120
TELEGRAM_API_RESPONSE_MAX_BYTES=1048576

# ERP/Odoo outbound SSRF policy — fail closed.
# Use exact hosts or controlled subdomain patterns such as *.odoo.example.com.
# A global * is forbidden. Private Odoo requires both an allowed hostname and the
# narrow RFC1918/ULA/CGNAT CIDR that contains the resolved address.
ERP_OUTBOUND_REQUIRE_ALLOWLIST=true
ERP_OUTBOUND_ALLOWED_HOSTS=
ERP_OUTBOUND_ALLOWED_CIDRS=
ERP_OUTBOUND_ALLOWED_PORTS=443
ERP_OUTBOUND_ALLOW_HTTP=false
ERP_OUTBOUND_CONNECT_TIMEOUT_SECONDS=10
ERP_OUTBOUND_READ_TIMEOUT_SECONDS=30
ERP_OUTBOUND_MAX_RESPONSE_BYTES=10485760

# File uploads
MAX_UPLOAD_SIZE_MB=10
MAX_PDF_PAGES=200
MAX_IMAGE_PIXELS=40000000
MAX_ARCHIVE_FILES=500
MAX_ARCHIVE_UNCOMPRESSED_MB=100
OCR_TIMEOUT_SECONDS=60
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.txt,.csv,.tsv,.xlsx,.ofx,.qfx,.qif,.mt940,.sta
CLAMAV_HOST=
CLAMAV_PORT=3310
REQUIRE_MALWARE_SCAN=false
STORAGE_DIR=

# Development-only owner bootstrap. Both values are required together; there are
# no default credentials, and production rejects any bootstrap values.
GUARDIAN_SEED_EMAIL=
GUARDIAN_SEED_PASSWORD=

# Public frontend build/runtime configuration. Must use HTTPS in production.
NEXT_PUBLIC_API_BASE_URL=

# Local LLM compatibility path. This service is loopback-only and has no external fallback.
LOCAL_LLM_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma2:9b
LOCAL_LLM_TIMEOUT_SECONDS=120
LOCAL_LLM_MAX_RESPONSE_BYTES=1048576

# External LLM disclosure boundary — disabled globally by default.
# An API key is only a technical credential. It does not grant tenant consent.
# Each organization must also store a current DPA acceptance and exact provider/model/purpose policy.
EXTERNAL_LLM_ENABLED=false
EXTERNAL_LLM_REQUIRED_DPA_VERSION=2026-07-v1
EXTERNAL_LLM_ALLOWED_PROVIDERS=deepseek
EXTERNAL_LLM_ALLOWED_MODELS=deepseek:deepseek-chat
EXTERNAL_LLM_ALLOWED_HOSTS=api.deepseek.com
EXTERNAL_LLM_MAX_REQUEST_BYTES=262144
EXTERNAL_LLM_MAX_RESPONSE_BYTES=1048576
EXTERNAL_LLM_MAX_REDACTED_TEXT_CHARS=4000
ACCOUNTING_LLM_PROVIDER=deepseek
ACCOUNTING_LLM_MODEL=deepseek-chat
ACCOUNTING_LLM_API_URL=https://api.deepseek.com/chat/completions
ACCOUNTING_LLM_TIMEOUT_SECONDS=45
ACCOUNTING_LLM_API_KEY=
DEEPSEEK_API_KEY=
