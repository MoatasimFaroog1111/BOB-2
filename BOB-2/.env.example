# GuardianAI Accountant & Auditor Enterprise — Environment
# Copy to .env. Never commit the populated .env file.

# Application
APP_NAME="GuardianAI Accountant & Auditor Enterprise"
APP_ENV=local
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
CORS_ORIGINS=
TRUSTED_HOSTS=
# Exact reverse-proxy IPs/CIDRs only. Leave empty when clients connect directly.
TRUSTED_PROXY_IPS=

# Database
# Local development may use sqlite:///./guardianai.db.
# Production must use PostgreSQL with a URL-encoded strong password.
POSTGRES_USER=guardian
POSTGRES_PASSWORD=
POSTGRES_DB=guardianai
DATABASE_URL=

# Shared rate limiting and session protection
REDIS_PASSWORD=
REDIS_URL=

# Security
# REQUIRED in production. Generate with: openssl rand -hex 64
SECRET_KEY=
REQUIRE_HTTPS=false
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=3

# File uploads
MAX_UPLOAD_SIZE_MB=10
MAX_PDF_PAGES=200
MAX_IMAGE_PIXELS=40000000
MAX_ARCHIVE_FILES=500
MAX_ARCHIVE_UNCOMPRESSED_MB=100
OCR_TIMEOUT_SECONDS=60
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.webp,.txt,.csv,.tsv,.xlsx,.xls,.ofx,.qfx,.qif,.mt940,.sta
STORAGE_DIR=

# Development-only owner bootstrap. There is no default password and production
# never creates an owner automatically. Leave empty unless deliberately bootstrapping local dev.
GUARDIAN_SEED_PASSWORD=

# Public frontend build configuration
NEXT_PUBLIC_API_BASE_URL=

# LLM / AI
DEEPSEEK_API_KEY=
