# ─────────────────────────────────────────────────────────────
# GuardianAI Accountant & Auditor Enterprise — Environment
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME="GuardianAI Accountant & Auditor Enterprise"
APP_ENV=local                       # local | development | staging | production

# ── Networking ───────────────────────────────────────────────
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:3000
# Comma-separated list of additional allowed CORS origins (production domains)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
# Comma-separated list of trusted hosts (used in production only)
# TRUSTED_HOSTS=example.com,*.example.com

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://guardian:guardian@localhost:5432/guardianai

# ── Security ─────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 64
SECRET_KEY=
REQUIRE_HTTPS=false                 # Set to true in production behind TLS
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=30

# ── Token Expiry ─────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── File Uploads ─────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.gif,.webp,.bmp,.tif,.tiff,.txt,.csv,.tsv,.xlsx,.xls,.xlsm,.ofx,.qfx,.qif,.mt940,.sta
STORAGE_DIR=                        # Defaults to <project_root>/storage

# ── Seed User ────────────────────────────────────────────────
GUARDIAN_SEED_PASSWORD=             # Defaults to Owner@Seed#2026!

# ── LLM / AI ────────────────────────────────────────────────
DEEPSEEK_API_KEY=                   # DeepSeek API key for AI features (https://platform.deepseek.com)

# ── Telegram Bot ─────────────────────────────────────────────
# Configured via the UI at /erp — no env var needed unless
# you want to pre-configure it.
