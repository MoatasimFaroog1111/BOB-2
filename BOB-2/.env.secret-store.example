# Central secret store deployment variables only. Do not put secret values here.
SECRET_STORE_PROVIDER=azure_key_vault
AZURE_KEY_VAULT_URL=https://your-application-vault.vault.azure.net
AZURE_MANAGED_IDENTITY_CLIENT_ID=
SECRET_STORE_CONNECT_TIMEOUT_SECONDS=5
SECRET_STORE_READ_TIMEOUT_SECONDS=15
SECRET_STORE_MAX_REQUEST_BYTES=262144
SECRET_STORE_MAX_RESPONSE_BYTES=1048576
TELEGRAM_RUNTIME_ORGANIZATION_ID=0
